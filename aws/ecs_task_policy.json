{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "InvokeBedrockModels",
      "Effect": "Allow",
      "Action": [
        "bedrock:InvokeModel",
        "bedrock:InvokeModelWithResponseStream",
        "bedrock:StartAsyncInvoke",
        "bedrock:GetAsyncInvoke",
        "bedrock:ListAsyncInvokes"
      ],
      "Resource": [
        "arn:aws:bedrock:*::foundation-model/eu.amazon.nova-pro-v1:0",
        "arn:aws:bedrock:*::foundation-model/qwen.qwen3-235b-a22b-2507-v1:0",
        "arn:aws:bedrock:*::foundation-model/openai.gpt-oss-120b-1:0",
        "arn:aws:bedrock:*::foundation-model/nvidia.nemotron-super-3-120b",
        "arn:aws:bedrock:*::foundation-model/mistral.devstral-2-123b",
        "arn:aws:bedrock:*::foundation-model/amazon.nova-reel-v1:1",
        "arn:aws:bedrock:*::foundation-model/amazon.nova-canvas-v1:0",
        "arn:aws:bedrock:*::foundation-model/amazon.titan-image-generator-v2:0",
        "arn:aws:bedrock:*::foundation-model/stability.stable-image-core-v1:1",
        "arn:aws:bedrock:*::foundation-model/stability.stable-image-ultra-v1:1",
        "arn:aws:bedrock:*::foundation-model/stability.sd3-5-large-v1:0",
        "arn:aws:bedrock:*:*:inference-profile/eu.amazon.nova-pro-v1:0",
        "arn:aws:bedrock:*:*:inference-profile/qwen.qwen3-235b-a22b-2507-v1:0",
        "arn:aws:bedrock:*:*:inference-profile/openai.gpt-oss-120b-1:0",
        "arn:aws:bedrock:*:*:inference-profile/nvidia.nemotron-super-3-120b",
        "arn:aws:bedrock:*:*:inference-profile/mistral.devstral-2-123b"
      ]
    },
    {
      "Sid": "ReadWriteAppBucketObjects",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:PutObject",
        "s3:DeleteObject"
      ],
      "Resource": "arn:aws:s3:::REPLACE_WITH_BUCKET_NAME/*"
    },
    {
      "Sid": "InspectAppBucket",
      "Effect": "Allow",
      "Action": [
        "s3:ListBucket"
      ],
      "Resource": "arn:aws:s3:::REPLACE_WITH_BUCKET_NAME"
    },
    {
      "Sid": "ReadAppSecrets",
      "Effect": "Allow",
      "Action": [
        "secretsmanager:GetSecretValue"
      ],
      "Resource": "arn:aws:secretsmanager:REPLACE_WITH_REGION:REPLACE_WITH_ACCOUNT_ID:secret:video-script-creator/*"
    }
  ]
}
