# Amazon Bedrock
BEDROCK_AWS_REGION=us-east-1
BEDROCK_MODEL_ID=eu.amazon.nova-pro-v1:0
BEDROCK_MAX_TOKENS=4096

# AWS credentials are normally provided by an ECS task role in production.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=

# Runtime persistence.
APP_DATA_DIR=/app/data
STORAGE_BACKEND=local

# Use these when STORAGE_BACKEND=s3.
# S3_BUCKET=video-script-creator-prod-assets
# S3_PREFIX=runtime

# Use this to persist parsed product features and future script history in RDS PostgreSQL.
# DATABASE_URL=postgresql://user:password@host:5432/video_script_creator

# Optional pilot access control.
# APP_ACCESS_PASSWORD=
# ALLOWED_HTTP_CIDRS=203.0.113.10/32,198.51.100.0/24
