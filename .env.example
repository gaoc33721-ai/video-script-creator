# Amazon Bedrock
BEDROCK_AWS_REGION=us-east-1
BEDROCK_MODEL_ID=eu.amazon.nova-pro-v1:0
BEDROCK_MAX_TOKENS=4096

# Nova Reel video-material PoC.
# Confirm model access and regional availability in Amazon Bedrock before enabling.
NOVA_REEL_AWS_REGION=us-east-1
NOVA_REEL_MODEL_ID=amazon.nova-reel-v1:1
# NOVA_REEL_OUTPUT_S3_URI=s3://video-script-creator-prod-assets/runtime/nova-reel-poc
NOVA_REEL_ESTIMATED_USD_PER_SECOND=0.08
NOVA_REEL_MAX_SUBMISSIONS_PER_CLICK=2

# Nova Canvas storyboard-reference-image generation.
# Confirm model access and regional availability in Amazon Bedrock before enabling.
NOVA_CANVAS_AWS_REGION=us-west-2
NOVA_CANVAS_MODEL_ID=stability.sd3-5-large-v1:0
NOVA_CANVAS_ESTIMATED_USD_PER_IMAGE=0.08
NOVA_CANVAS_REFERENCE_STRENGTH=0.9

# Optional third-party image provider for storyboard images.
# Use liblibai in production after configuring LIBLIBAI_* secrets.
MEDIA_IMAGE_PROVIDER=nova_canvas
LIBLIBAI_BASE_URL=https://openapi.liblibai.cloud
LIBLIBAI_TEMPLATE_UUID=5d7e67009b344550bc1aa6ccbfa1d7f4
LIBLIBAI_IMAGE_MODEL_LABEL=liblibai:star-3-alpha
LIBLIBAI_IMAGE_ASPECT_RATIO=landscape
LIBLIBAI_IMAGE_STEPS=20
# LIBLIBAI_ACCESS_KEY=
# LIBLIBAI_SECRET_KEY=
# LIBLIBAI_ACCESS_KEY_SECRET_NAME=video-script-creator/liblibai-access-key
# LIBLIBAI_SECRET_KEY_SECRET_NAME=video-script-creator/liblibai-secret-key

# AWS credentials are normally provided by an ECS task role in production.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=

# Runtime persistence.
APP_DATA_DIR=/app/data
STORAGE_BACKEND=local

# Use these when STORAGE_BACKEND=s3.
# S3_BUCKET=video-script-creator-prod-assets
# S3_PREFIX=runtime

# Use this to persist parsed product features and future script history in RDS PostgreSQL.
# DATABASE_URL=postgresql://user:password@host:5432/video_script_creator

# Optional pilot access control.
# Access control is enabled automatically when APP_ACCESS_PASSWORD or an
# APP_ACCESS_PASSWORD_SECRET_* value is configured. Set to false to disable.
APP_ACCESS_CONTROL_ENABLED=auto
# APP_ACCESS_PASSWORD=
# APP_ACCESS_PASSWORD_SECRET_NAME=video-script-creator/app-access-password
# APP_ACCESS_PASSWORD_SECRET_ARN=
# APP_ACCESS_PASSWORD_SECRET_ID=
# APP_ACCESS_PASSWORD_SECRET_REGION=us-east-1
# APP_ACCESS_PASSWORD_CACHE_TTL=300
# ALLOWED_HTTP_CIDRS=203.0.113.10/32,198.51.100.0/24
